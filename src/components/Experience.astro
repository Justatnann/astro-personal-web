---
import "../styles/global.css";
---

<section id="career" class="py-24 px-6">
  <div class="max-w-6xl mx-auto grid gap-16 md:grid-cols-2">

    <!-- ================= EXPERIENCE ================= -->
    <div>
      <h2 class="font-dot text-center md:text-left text-4xl md:text-5xl tracking-[0.3em] mb-16">
        EXPERIENCE
      </h2>

      <div class="space-y-6">

        <!-- Card -->
        <div class="bg-white rounded-xl p-8 border border-black/20 flex flex-col">
          <p class="font-archimotov text-sm opacity-60 mb-2">2025 – Present</p>

          <h3 class="font-archimotov-bold text-xl mb-2">Purchasing</h3>

          <p class="text-sm leading-relaxed mb-3">
            Handled purchasing activities to ensure timely procurement of goods
            while maintaining cost efficiency and supplier relationships.
          </p>

          <ul class="text-sm font-archimotov list-disc list-inside space-y-1 mb-4">
            <li class="font-archimotov">Created and tracked purchase orders</li>
            <li class="font-archimotov">
              Coordinated with suppliers and internal departments
            </li>
            <li class="font-archimotov">
              Verified invoices against purchase orders and deliveries
            </li>
            <li class="font-archimotov">
              Maintained inventory and procurement records
            </li>
          </ul>

          <div class="flex flex-wrap gap-2 text-xs font-archimotov mb-4">
            <span class="border px-3 py-1 rounded-full">Procurement</span>
            <span class="border px-3 py-1 rounded-full">Vendor Management</span>
            <span class="border px-3 py-1 rounded-full">Cost Control</span>
            <span class="border px-3 py-1 rounded-full">Documentation</span>
          </div>

          <div class="font-archimotov-bold text-center text-lg rounded-lg bg-black text-white p-4 mt-auto">
            PT NG TECH SUPPLIES
          </div>
        </div>

        <!-- Card -->
        <div class="bg-white rounded-xl p-8 border border-black/20 flex flex-col">
          <p class="font-archimotov text-sm opacity-60 mb-2">2022 – 2024</p>

          <h3 class="font-archimotov-bold text-xl mb-2">AP / AR Accountant</h3>

          <p class="text-sm leading-relaxed mb-3">
            Responsible for managing accounts payable and receivable processes,
            ensuring accurate financial records and timely transactions.
          </p>

          <ul class="text-sm font-archimotov list-disc list-inside space-y-1 mb-4">
            <li class="font-archimotov">
              Processed vendor invoices and payment schedules
            </li>
            <li class="font-archimotov">
              Monitored receivables and followed up on outstanding balances
            </li>
            <li class="font-archimotov">
              Reconciled accounts and supported monthly closing
            </li>
            <li class="font-archimotov">
              Maintained accurate financial documentation
            </li>
          </ul>

          <div class="flex flex-wrap gap-2 text-xs font-archimotov mb-4">
            <span class="border px-3 py-1 rounded-full">Accounts Payable</span>
            <span class="border px-3 py-1 rounded-full">Accounts Receivable</span>
            <span class="border px-3 py-1 rounded-full">Reconciliation</span>
            <span class="border px-3 py-1 rounded-full">Excel</span>
          </div>

          <div class="font-archimotov-bold text-center text-lg rounded-lg bg-black text-white p-4 mt-auto">
            PT INTERNATIONAL HARDWARE INDO
          </div>
        </div>

      </div>
    </div>

    <!-- ================= EDUCATION ================= -->
    <div>
      <h2 class="font-dot text-center md:text-right text-4xl md:text-5xl tracking-[0.3em] mb-16">
        EDUCATION
      </h2>

      <div class="space-y-6">

        <!-- Card -->
        <div class="bg-white rounded-xl p-8 border border-black/20 flex flex-col">
          <p class="font-archimotov text-sm opacity-60 mb-2">2021 – 2025</p>

          <h3 class="font-archimotov-bold text-xl mb-2">
            Bachelor of Information Systems
          </h3>

          <p class="text-sm leading-relaxed mb-3">
            Universitas Internasional Batam
          </p>

          <ul class="text-sm font-archimotov list-disc list-inside space-y-1 mb-4">
            <li>Focused on Software Engineering and Mobile Development</li>
            <li>Developed multiple Flutter-based applications</li>
            <li>Worked on the Healcation wellness travel app project</li>
          </ul>

          <div class="flex flex-wrap gap-2 text-xs font-archimotov mb-4">
            <span class="border px-3 py-1 rounded-full">Flutter</span>
            <span class="border px-3 py-1 rounded-full">Mobile Development</span>
            <span class="border px-3 py-1 rounded-full">UI/UX</span>
            <span class="border px-3 py-1 rounded-full">Software Engineering</span>
          </div>

          <div class="font-archimotov-bold text-center text-lg rounded-lg bg-black text-white p-4 mt-auto">
            UNIVERSITAS INTERNASIONAL BATAM
          </div>
        </div>
        <div class="bg-white rounded-xl p-8 border border-black/20 flex flex-col">
          <p class="font-archimotov text-sm opacity-60 mb-2">2019 – 2022</p>

          <h3 class="font-archimotov-bold text-xl mb-2">
            Social Studies Major, Economy and Accounting
          </h3>

          <p class="text-sm leading-relaxed mb-3">
            SMA ANANDA BATAM
          </p>

          <ul class="text-sm font-archimotov list-disc list-inside space-y-1 mb-4">
            <li>Studied Social Studies with a focus on Economy and Accounting</li>
            <li>Developed a strong foundation in economic principles and accounting practices</li>
            <li>Worked on various assignments related to economic analysis and financial reporting</li>
          </ul>

          <div class="flex flex-wrap gap-2 text-xs font-archimotov mb-4">
            <span class="border px-3 py-1 rounded-full">Economy</span>
            <span class="border px-3 py-1 rounded-full">Social Studies</span>
            <span class="border px-3 py-1 rounded-full">Accounting</span>
          </div>

          <div class="font-archimotov-bold text-center text-lg rounded-lg bg-black text-white p-4 mt-auto">
            SMA ANANDA BATAM
          </div>
        </div>
      </div>
    </div>

  </div>
</section>